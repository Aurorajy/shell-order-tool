# ============================================================
# 壳牌订单调度工具 - 配置文件（模板）
# 复制此文件为 .env 并填入真实信息，.env 不会被 git 提交
# ============================================================

# SDCC 登录
SDCC_USERNAME=你的手机号
SDCC_PASSWORD=你的密码
SDCC_PROJECT=壳牌天津8222

# QQ邮箱（收客户邮件 + 发调度表）
QQ_EMAIL=你的QQ号@qq.com
QQ_AUTH_CODE=你的QQ邮箱授权码

# 承运商邮箱（待补充）
