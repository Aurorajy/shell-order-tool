# ============================================================
# 壳牌订单调度工具 - 配置文件（模板）
# 复制此文件为 .env 并填入真实信息，.env 不会被 git 提交
# ============================================================

# SDCC 登录
SDCC_USERNAME=你的手机号
SDCC_PASSWORD=你的密码
SDCC_PROJECT=壳牌天津8222

# 公司邮箱（收客户邮件 + 发调度表）
EMAIL_IMAP_SERVER=邮件服务器IP或主机名
EMAIL_IMAP_PORT=993
EMAIL_SMTP_SERVER=邮件服务器IP或主机名
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=邮箱用户名
EMAIL_PASSWORD=邮箱密码
EMAIL_SENDER=发件人地址
