# ============================================================
# 壳牌订单调度工具 - 配置文件（模板）
# 复制此文件为 .env 并填入真实信息，.env 不会被 git 提交
# ============================================================

# ---------- 测试模式 ----------
# DRY_RUN=1

# ---------- SDCC 系统 ----------
SDCC_USERNAME=你的手机号
SDCC_PASSWORD=你的密码
SDCC_PROJECT=壳牌天津8222

# ---------- 公司邮箱（收客户邮件 + 发调度表）----------
EMAIL_IMAP_SERVER=邮件服务器IP或主机名
EMAIL_IMAP_PORT=993
EMAIL_SMTP_SERVER=邮件服务器IP或主机名
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=邮箱用户名
EMAIL_PASSWORD=邮箱密码
EMAIL_SENDER=发件人地址

# ---------- 调度总表收件人 ----------
# 多个邮箱用分号(;)分隔
MASTER_RECIPIENTS=shelldispatchtj@sinotrans.com;caimeng1@cmhk.com;lixuekuan@cmhk.com;liushuo2@cmhk.com
UNMATCHED_RECIPIENT=shelldispatchtj@sinotrans.com

# ---------- 承运商配置 ----------
# 承运商列表，用竖线(|)分隔
CARRIER_LIST=奥联|富力达|汇利|联众|津京通达|金博通

# 每个承运商的省份（逗号分隔）
CARRIER_奥联_省=黑龙江,吉林
CARRIER_富力达_省=河北,辽宁
CARRIER_汇利_省=内蒙古,新疆,青海,河南,山西,西藏
CARRIER_联众_省=山东
CARRIER_津京通达_省=天津
CARRIER_金博通_省=海南,重庆,四川,江西,福建,安徽,湖南,湖北,广东,贵州,云南,广西,浙江,上海,江苏

